-- Variables
local flySpeed = 100
local flying = false
local sharksFrozen = false
local bv, bg -- Body objects for flying

-- Optimized Button Function
local function createBtn(text, pos, color, callback)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0.85, 0, 0, 35)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.Font = Enum.Font.SourceSansBold
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextSize = 16
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- 1. FLY LOGIC (REFIXED)
local function toggleFly()
    flying = not flying
    if flying then
        humanoid.PlatformStand = true
        bv = Instance.new("BodyVelocity", rootPart)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Velocity = Vector3.new(0,0,0)
        
        bg = Instance.new("BodyGyro", rootPart)
        bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        bg.P = 15000
    else
        if bv then bv:Destroy() end
        if bg then bg:Destroy() end
        humanoid.PlatformStand = false
    end
end

createBtn("TOGGLE FLY (F)", UDim2.new(0.075, 0, 0.12, 0), Color3.fromRGB(80, 80, 80), toggleFly)

