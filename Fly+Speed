local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- UI Setup
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player.PlayerGui
screenGui.Name = "StudFlyUI"
screenGui.ResetOnSpawn = false

-- Main Frame
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 250, 0, 400) -- Increased size for new slider
frame.Position = UDim2.new(0.5, -125, 0.1, 0)
frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true
frame.Parent = screenGui
Instance.new("UICorner", frame)

-- Title
local titleLabel = Instance.new("TextLabel", frame)
titleLabel.Size = UDim2.new(1, 0, 0, 30)
titleLabel.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
titleLabel.Text = "STUD EXPLOIT (BRAINROT ED.)"
titleLabel.TextColor3 = Color3.fromRGB(0, 0, 0)
titleLabel.Font = Enum.Font.FredokaOne
titleLabel.TextSize = 16
Instance.new("UICorner", titleLabel)

-- Helper Button Function
local function createStudButton(name, pos, color)
    local btn = Instance.new("TextButton", frame)
    btn.Name = name
    btn.Size = UDim2.new(0.8, 0, 0, 35)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Font = Enum.Font.FredokaOne
    btn.TextSize = 16
    btn.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
    return btn
end

local flyButton = createStudButton("FlyBtn", UDim2.new(0.1, 0, 0.1, 0), Color3.fromRGB(200, 0, 0))
flyButton.Text = "FLY: OFF"

local noclipButton = createStudButton("NoclipBtn", UDim2.new(0.1, 0, 0.22, 0), Color3.fromRGB(50, 50, 50))
noclipButton.Text = "NOCLIP: OFF"

local walkButton = createStudButton("WalkBtn", UDim2.new(0.1, 0, 0.34, 0), Color3.fromRGB(0, 100, 200))
walkButton.Text = "WALK SPEED: OFF"

-- Variables
local flySpeed, boatSpeed, walkSpeedVal = 50, 50, 16
local flying, noclip, walkEnabled = false, false, false
local flyConnection

-- Boat Speed Logic
local function updateBoatSpeed(val)
    boatSpeed = val
    if humanoid.SeatPart and humanoid.SeatPart:IsA("VehicleSeat") then
        local seat = humanoid.SeatPart
        seat.MaxSpeed = val
        seat.Torque = val * 2 -- Ensures enough power to push the boat
    end
end

-- Fly Logic
local function toggleFly()
    flying = not flying
    flyButton.Text = "FLY: " .. (flying and "ON" or "OFF")
    flyButton.BackgroundColor3 = flying and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
    
    if flying then
        humanoid.PlatformStand = true
        local bg = Instance.new("BodyGyro", rootPart)
        bg.Name = "FlyGyro"
        bg.P = 9e4
        bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        
        local bv = Instance.new("BodyVelocity", rootPart)
        bv.Name = "FlyVelocity"
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)

        flyConnection = RunService.RenderStepped:Connect(function()
            local cam = workspace.CurrentCamera.CFrame
            local moveDir = Vector3.new(0,0,0)
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += cam.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= cam.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= cam.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += cam.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir -= Vector3.new(0,1,0) end
            
            bg.CFrame = cam
            bv.Velocity = (moveDir.Magnitude > 0) and (moveDir.Unit * flySpeed) or Vector3.new(0,0,0)
        end)
    else
        if flyConnection then flyConnection:Disconnect() end
        if rootPart:FindFirstChild("FlyGyro") then rootPart.FlyGyro:Destroy() end
        if rootPart:FindFirstChild("FlyVelocity") then rootPart.FlyVelocity:Destroy() end
        humanoid.PlatformStand = false
    end
end

-- Slider Function
local function createSlider(labelName, pos, min, max, default, callback)
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(0.8, 0, 0, 20)
    label.Position = pos
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1,1,1)
    label.Text = labelName .. ": " .. default
    label.Font = Enum.Font.SourceSansBold

    local track = Instance.new("Frame", frame)
    track.Size = UDim2.new(0.8, 0, 0, 6)
    track.Position = pos + UDim2.new(0, 0, 0, 22)
    track.BackgroundColor3 = Color3.fromRGB(60, 60, 60)

    local thumb = Instance.new("TextButton", track)
    thumb.Size = UDim2.new(0, 15, 0, 15)
    thumb.Position = UDim2.new(0, 0, 0.5, -7)
    thumb.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    thumb.Text = ""

    local dragging = false
    thumb.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    
    RunService.RenderStepped:Connect(function()
        if dragging then
            local relativePos = math.clamp((UserInputService:GetMouseLocation().X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            thumb.Position = UDim2.new(relativePos, -7, 0.5, -7)
            local val = math.floor(min + (relativePos * (max - min)))
            label.Text = labelName .. ": " .. val
            callback(val)
        end
    end)
end

-- Create Sliders
createSlider("Fly Speed", UDim2.new(0.1, 0, 0.48, 0), 10, 500, 50, function(v) flySpeed = v end)
createSlider("Walk Speed", UDim2.new(0.1, 0, 0.64, 0), 16, 500, 16, function(v) 
    walkSpeedVal = v 
    if walkEnabled then humanoid.WalkSpeed = v end 
end)
createSlider("Boat Speed", UDim2.new(0.1, 0, 0.80, 0), 20, 1000, 50, updateBoatSpeed)

-- Connections
flyButton.MouseButton1Click:Connect(toggleFly)
noclipButton.MouseButton1Click:Connect(toggleNoclip)
walkButton.MouseButton1Click:Connect(function()
    walkEnabled = not walkEnabled
    walkButton.Text = "WALK: " .. (walkEnabled and "ON" or "OFF")
    humanoid.WalkSpeed = walkEnabled and walkSpeedVal or 16
end)

RunService.Stepped:Connect(function()
    if noclip and character then
        for _, part in pairs(character:GetChildren()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
end)

UserInputService.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode == Enum.KeyCode.RightAlt then frame.Visible = not frame.Visible end
end)
