-- 5. SPEED SLIDER (Boat & Walk)
local function createSlider(name, pos, min, max, def, cb)
    local lab = Instance.new("TextLabel", frame)
    lab.Size = UDim2.new(0.9, 0, 0, 20); lab.Position = pos; lab.Text = name .. ": " .. def; lab.TextColor3 = Color3.new(1,1,1); lab.BackgroundTransparency = 1; lab.Font = Enum.Font.SourceSansBold
    local trk = Instance.new("Frame", frame); trk.Size = UDim2.new(0.9, 0, 0, 6); trk.Position = pos + UDim2.new(0,0,0,22); trk.BackgroundColor3 = Color3.fromRGB(40,40,40)
    local thm = Instance.new("TextButton", trk); thm.Size = UDim2.new(0, 14, 0, 14); thm.Position = UDim2.new(0,0,0.5,-7); thm.BackgroundColor3 = Color3.fromRGB(255,215,0); thm.Text = ""
    local drag = false
    thm.MouseButton1Down:Connect(function() drag = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
    RunService.RenderStepped:Connect(function()
        if drag then
            local rel = math.clamp((UserInputService:GetMouseLocation().X - trk.AbsolutePosition.X) / trk.AbsoluteSize.X, 0, 1)
            thm.Position = UDim2.new(rel, -7, 0.5, -7)
            local val = math.floor(min + (rel * (max - min)))
            lab.Text = name .. ": " .. val
            cb(val)
        end
    end)
end

createSlider("Boat & Walk Speed", UDim2.new(0.05, 0, 0.55, 0), 16, 3000, 16, function(v) humanoid.WalkSpeed = v end)
createSlider("Fly Speed", UDim2.new(0.05, 0, 0.72, 0), 10, 1000, 100, function(v) flySpeed = v end)

-- FLY ENGINE
RunService.RenderStepped:Connect(function()
    if flying and rootPart:FindFirstChild("StudFlyVel") then
        local cam = workspace.CurrentCamera.CFrame
        local dir = Vector3.new(0,0,0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += cam.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= cam.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= cam.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += cam.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0,1,0) end
        
        rootPart.StudFlyGyro.CFrame = cam
        rootPart.StudFlyVel.Velocity = dir * flySpeed
    end
end)

