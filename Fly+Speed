local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- UI Setup
local screenGui = Instance.new("ScreenGui", player.PlayerGui)
screenGui.Name = "BrainrotStudUI"
screenGui.ResetOnSpawn = false

-- Main Frame
local frame = Instance.new("Frame", screenGui)
frame.Size = UDim2.new(0, 260, 0, 420)
frame.Position = UDim2.new(0.5, -130, 0.2, 0)
frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
frame.BorderSizePixel = 0
frame.Active = true
frame.Draggable = true
Instance.new("UICorner", frame)

-- Title
local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1, 0, 0, 35)
title.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
title.Text = "BRAINROT SAILING HUB"
title.TextColor3 = Color3.new(0,0,0)
title.Font = Enum.Font.FredokaOne
title.TextSize = 18
Instance.new("UICorner", title)

-- Variables
local boatWalkSpeed = 16
local sharksFrozen = false

-- Button Creator
local function createBtn(text, pos, color, callback)
    local btn = Instance.new("TextButton", frame)
    btn.Size = UDim2.new(0.8, 0, 0, 35)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.Font = Enum.Font.FredokaOne
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextSize = 14
    Instance.new("UICorner", btn)
    btn.MouseButton1Click:Connect(callback)
    return btn
end

-- Freeze Sharks Logic
local freezeBtn = createBtn("FREEZE SHARKS: OFF", UDim2.new(0.1, 0, 0.12, 0), Color3.fromRGB(100, 0, 0), function()
    sharksFrozen = not sharksFrozen
end)

RunService.Heartbeat:Connect(function()
    if sharksFrozen then
        for _, v in pairs(workspace:GetDescendants()) do
            if v.Name:find("Shark") and v:IsA("Model") then
                local rp = v:FindFirstChild("HumanoidRootPart") or v.PrimaryPart
                if rp then rp.Anchored = true end
            end
        end
    end
end)

-- Spawn Brainrot Logic
createBtn("SPAWN BRAINROT", UDim2.new(0.1, 0, 0.23, 0), Color3.fromRGB(0, 150, 0), function()
    -- Attempts to fire common spawn remotes found in brainrot games
    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("SpawnBrainrot") or 
                   game:GetService("ReplicatedStorage"):FindFirstChild("Summon")
    if remote and remote:IsA("RemoteEvent") then
        remote:FireServer()
    else
        print("Brainrot Remote Not Found")
    end
end)

-- Fly Toggle
local flying = false
local flyBtn = createBtn("FLY: OFF", UDim2.new(0.1, 0, 0.34, 0), Color3.fromRGB(50, 50, 50), function()
    flying = not flying
end)

-- Slider Logic for Boat/Walk Speed
local function createSlider(labelName, pos, min, max, default, callback)
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(0.8, 0, 0, 20)
    label.Position = pos
    label.Text = labelName .. ": " .. default
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.SourceSansBold

    local track = Instance.new("Frame", frame)
    track.Size = UDim2.new(0.8, 0, 0, 6)
    track.Position = pos + UDim2.new(0, 0, 0, 22)
    track.BackgroundColor3 = Color3.fromRGB(60, 60, 60)

    local thumb = Instance.new("TextButton", track)
    thumb.Size = UDim2.new(0, 15, 0, 15)
    thumb.Position = UDim2.new(0, 0, 0.5, -7)
    thumb.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    thumb.Text = ""

    local dragging = false
    thumb.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    
    RunService.RenderStepped:Connect(function()
        if dragging then
            local relativePos = math.clamp((UserInputService:GetMouseLocation().X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            thumb.Position = UDim2.new(relativePos, -7, 0.5, -7)
            local val = math.floor(min + (relativePos * (max - min)))
            label.Text = labelName .. ": " .. val
            callback(val)
        end
    end)
end

-- Updated: Walk Speed Slider (This also speeds up the boat!)
createSlider("Boat & Walk Speed", UDim2.new(0.1, 0, 0.55, 0), 16, 1000, 16, function(v)
    boatWalkSpeed = v
    humanoid.WalkSpeed = v
end)

-- Fly System
RunService.RenderStepped:Connect(function()
    flyBtn.Text = "FLY: " .. (flying and "ON" or "OFF")
    if flying then
        humanoid.PlatformStand = true
        local moveDir = Vector3.new(0,0,0)
        local cam = workspace.CurrentCamera.CFrame
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += cam.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= cam.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= cam.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += cam.RightVector end
        
        rootPart.Velocity = moveDir * 100 -- Constant fly speed
    elseif not flying and humanoid.PlatformStand then
        humanoid.PlatformStand = false
    end
end)

-- Right Alt to Hide
UserInputService.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode == Enum.KeyCode.RightAlt then frame.Visible = not frame.Visible end
end)
