-- 4. BOAT / WALK SPEED SLIDER
local function createSlider(labelName, pos, min, max, default, callback)
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(0.8, 0, 0, 20)
    label.Position = pos
    label.Text = labelName .. ": " .. default
    label.TextColor3 = Color3.new(1,1,1)
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.SourceSansBold

    local track = Instance.new("Frame", frame)
    track.Size = UDim2.new(0.85, 0, 0, 6)
    track.Position = pos + UDim2.new(0, 0, 0, 22)
    track.BackgroundColor3 = Color3.fromRGB(40, 40, 40)

    local thumb = Instance.new("TextButton", track)
    thumb.Size = UDim2.new(0, 14, 0, 14)
    thumb.Position = UDim2.new(0, 0, 0.5, -7)
    thumb.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    thumb.Text = ""

    local dragging = false
    thumb.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    
    RunService.RenderStepped:Connect(function()
        if dragging then
            local rel = math.clamp((UserInputService:GetMouseLocation().X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            thumb.Position = UDim2.new(rel, -7, 0.5, -7)
            local val = math.floor(min + (rel * (max - min)))
            label.Text = labelName .. ": " .. val
            callback(val)
        end
    end)
end

createSlider("Boat/Walk Speed", UDim2.new(0.075, 0, 0.45, 0), 16, 1500, 16, function(v)
    humanoid.WalkSpeed = v
end)

createSlider("Fly Speed", UDim2.new(0.075, 0, 0.60, 0), 10, 500, 100, function(v)
    flySpeed = v
end)

-- FLY LOOP
RunService.RenderStepped:Connect(function()
    if flying and bv and bg then
        local cam = workspace.CurrentCamera.CFrame
        local dir = Vector3.new(0,0,0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += cam.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= cam.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= cam.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += cam.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir += Vector3.new(0,1,0) end
        
        bg.CFrame = cam
        bv.Velocity = dir * flySpeed
    end
end)

-- HOTKEYS
UserInputService.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.F then toggleFly() end
    if i.KeyCode == Enum.KeyCode.RightAlt then frame.Visible = not frame.Visible end
end)
