local noclipButton = createStudButton("NoclipBtn", UDim2.new(0.1, 0, 0.3, 0), Color3.fromRGB(50, 50, 50))
noclipButton.Text = "NOCLIP: OFF"

local walkSpeedButton = createStudButton("WalkBtn", UDim2.new(0.1, 0, 0.45, 0), Color3.fromRGB(0, 100, 200))
walkSpeedButton.Text = "WALK SPEED: OFF"

-- Variables
local flySpeed = 50
local customWalkSpeed = 16
local flying = false
local noclip = false
local walkSpeedEnabled = false
local flyConnection

-- Optimized Fly Logic
local function toggleFly()
    flying = not flying
    flyButton.Text = "FLY: " .. (flying and "ON" or "OFF")
    flyButton.BackgroundColor3 = flying and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
    
    if flying then
        humanoid.PlatformStand = true
        local bg = Instance.new("BodyGyro", rootPart)
        bg.Name = "FlyGyro"
        bg.P = 9e4
        bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        bg.CFrame = rootPart.CFrame
        
        local bv = Instance.new("BodyVelocity", rootPart)
        bv.Name = "FlyVelocity"
        bv.Velocity = Vector3.new(0,0,0)
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)

        flyConnection = RunService.RenderStepped:Connect(function()
            local cam = workspace.CurrentCamera.CFrame
            local moveDir = Vector3.new(0,0,0)
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += cam.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= cam.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= cam.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += cam.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then moveDir -= Vector3.new(0,1,0) end
            
            bg.CFrame = cam
            if moveDir.Magnitude > 0 then
                bv.Velocity = moveDir.Unit * flySpeed
            else
                bv.Velocity = Vector3.new(0,0,0)
            end
        end)
    else
        if flyConnection then flyConnection:Disconnect() end
        if rootPart:FindFirstChild("FlyGyro") then rootPart.FlyGyro:Destroy() end
        if rootPart:FindFirstChild("FlyVelocity") then rootPart.FlyVelocity:Destroy() end
        humanoid.PlatformStand = false
    end
end

-- Optimized Noclip (No Lag)
local function toggleNoclip()
    noclip = not noclip
    noclipButton.Text = "NOCLIP: " .. (noclip and "ON" or "OFF")
    noclipButton.BackgroundColor3 = noclip and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(50, 50, 50)
end

RunService.Stepped:Connect(function()
    if noclip and character then
        for _, part in pairs(character:GetChildren()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

-- Walkspeed
local function toggleWalk()
    walkSpeedEnabled = not walkSpeedEnabled
    walkSpeedButton.Text = "WALK: " .. (walkSpeedEnabled and "ON" or "OFF")
    humanoid.WalkSpeed = walkSpeedEnabled and customWalkSpeed or 16
end

-- Slider Logic
local function createSlider(labelName, pos, min, max, default)
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(0.8, 0, 0, 20)
    label.Position = pos
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1,1,1)
    label.Text = labelName .. ": " .. default
    label.Font = Enum.Font.SourceSansBold

    local track = Instance.new("Frame", frame)
    track.Size = UDim2.new(0.8, 0, 0, 6)
    track.Position = pos + UDim2.new(0, 0, 0, 22)
    track.BackgroundColor3 = Color3.fromRGB(100, 100, 100)

    local thumb = Instance.new("TextButton", track)
    thumb.Size = UDim2.new(0, 15, 0, 15)
    thumb.Position = UDim2.new(0, 0, 0.5, -7)
    thumb.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    thumb.Text = ""

    local dragging = false
    thumb.MouseButton1Down:Connect(function() dragging = true end)
    UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    
    RunService.RenderStepped:Connect(function()
        if dragging then
            local mousePos = UserInputService:GetMouseLocation().X
            local relativePos = math.clamp((mousePos - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
            thumb.Position = UDim2.new(relativePos, -7, 0.5, -7)
            local val = math.floor(min + (relativePos * (max - min)))
            label.Text = labelName .. ": " .. val
            if labelName == "Fly Speed" then flySpeed = val 
            else 
                customWalkSpeed = val 
                if walkSpeedEnabled then humanoid.WalkSpeed = val end
            end
        end
    end)
end

createSlider("Fly Speed", UDim2.new(0.1, 0, 0.62, 0), 10, 500, 50)
createSlider("Walk Speed", UDim2.new(0.1, 0, 0.78, 0), 16, 500, 16)

flyButton.MouseButton1Click:Connect(toggleFly)
noclipButton.MouseButton1Click:Connect(toggleNoclip)
walkSpeedButton.MouseButton1Click:Connect(toggleWalk)

UserInputService.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.RightAlt then frame.Visible = not frame.Visible end
    if i.KeyCode == Enum.KeyCode.F then toggleFly() end
end)

TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Back), {Position = UDim2.new(0.5, -125, 0.1, 0)}):Play()
