-- [[ FEATURES LOGIC ]] --

-- 1. Improved Fly
local function toggleFly()
    flying = not flying
    if flying then
        local bv = Instance.new("BodyVelocity", rootPart)
        bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bv.Velocity = Vector3.new(0,0.1,0)
        bv.Name = "StudFly"
        task.spawn(function()
            while flying do
                local cam = workspace.CurrentCamera.CFrame
                local dir = Vector3.new(0,0,0)
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.RightVector end
                bv.Velocity = dir * flySpeed
                task.wait()
            end
            if rootPart:FindFirstChild("StudFly") then rootPart.StudFly:Destroy() end
        end)
    end
end

-- 2. God Mode (Rename Humanoid Trick)
local function toggleGod()
    godMode = not godMode
    if godMode then
        local oldH = character:FindFirstChildOfClass("Humanoid")
        local newH = oldH:Clone()
        newH.Parent = character
        oldH:Destroy()
        player.Character = character
    else
        character:BreakJoints() -- Reset to normal
    end
end

-- 3. Shark Disabler
local function killSharks()
    sharksDisabled = not sharksDisabled
    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name:lower():find("shark") or v.Name:lower():find("mega") then
            if v:IsA("Model") then v:MoveTo(Vector3.new(0, -1000, 0)) end
        end
    end
end

-- 4. Auto-Collect + Safe TP
task.spawn(function()
    while task.wait(0.5) do
        if autoCollect then
            for _, v in pairs(workspace:GetDescendants()) do
                if (v.Name:find("Block") or v.Name:find("Rot")) and v:IsA("BasePart") then
                    v.CFrame = rootPart.CFrame
                    firetouchinterest(rootPart, v, 0)
                    task.wait()
                    firetouchinterest(rootPart, v, 1)
                end
            end
        end
        -- Safe TP Logic
        if godMode == false and humanoid.Health < 20 then
            rootPart.CFrame = baseCFrame
        end
    end
end)

