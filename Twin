btn("TP TO BASE", Color3.fromRGB(80, 80, 80), function() player.Character.PrimaryPart.CFrame = baseCFrame end)
btn("SET BASE HERE", Color3.fromRGB(40, 40, 40), function() baseCFrame = player.Character.PrimaryPart.CFrame end)

-- [[ MOVEMENT HANDLERS ]] --
game:GetService("RunService").Stepped:Connect(function()
    if _G.Noclip and player.Character then
        for _, v in pairs(player.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)

-- Fly logic
task.spawn(function()
    while task.wait() do
        if _G.Flying and player.Character then
            local p = player.Character.PrimaryPart
            local cam = workspace.CurrentCamera.CFrame
            local move = Vector3.new(0,0,0)
            if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.W) then move = move + cam.LookVector end
            if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.S) then move = move - cam.LookVector end
            p.Velocity = move * flySpeed
        end
    end
end)

-- Keybind to Toggle Menu
game:GetService("UserInputService").InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.RightAlt then frame.Visible = not frame.Visible end
end)

print("STUD MASTER RECOVERED - Press RightAlt to Toggle")
