-- Button Function
local function btn(txt, color, func)
    local b = Instance.new("TextButton", scroll)
    b.Size = UDim2.new(0.95, 0, 0, 35)
    b.BackgroundColor3 = color
    b.Text = txt
    b.TextColor3 = Color3.new(1,1,1)
    b.Font = Enum.Font.SourceSansBold
    b.MouseButton1Click:Connect(func)
    Instance.new("UICorner", b)
end

-- [[ THE "EVERYTHING" LOGIC ]] --

-- 1. Fixed God Mode
task.spawn(function()
    while task.wait() do
        if _G.GodMode and player.Character then
            local hum = player.Character:FindFirstChildOfClass("Humanoid")
            if hum then 
                hum.Health = hum.MaxHealth 
                -- Prevents "Stuck in Void"
                if player.Character.PrimaryPart.Position.Y < -500 then
                    player.Character.PrimaryPart.CFrame = baseCFrame
                end
            end
        end
    end
end)

-- 2. Auto TP-Collector
task.spawn(function()
    while task.wait(0.5) do
        if _G.AutoTP and player.Character then
            for _, v in pairs(workspace:GetDescendants()) do
                if (v.Name:find("Block") or v.Name:find("Rot") or v.Name:find("Lucky")) then
                    local target = v:IsA("BasePart") and v or v:FindFirstChildWhichIsA("BasePart")
                    if target then
                        local lastPos = player.Character.PrimaryPart.CFrame
                        player.Character.PrimaryPart.CFrame = target.CFrame
                        firetouchinterest(player.Character.PrimaryPart, target, 0)
                        task.wait(0.1)
                        firetouchinterest(player.Character.PrimaryPart, target, 1)
                        player.Character.PrimaryPart.CFrame = lastPos
                    end
                end
            end
        end
    end
end)

