local flySpeed = 50
local walkSpeedVal = 16
local flying = false
local noclipMode = false
local bodyVelocity, bodyGyro

-- Slider Logic
local function handleSlider(thumb, track, min, max, callback)
	thumb.MouseButton1Down:Connect(function()
		local connection
		connection = UserInputService.InputChanged:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseMovement then
				local rel = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
				thumb.Position = UDim2.new(rel, -7, 0.5, -7)
				local val = math.floor(min + (rel * (max - min)))
				callback(val)
			end
		end)
		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				if connection then connection:Disconnect() end
			end
		end)
	end)
end

handleSlider(flyThumb, flyTrack, 10, 200, function(v) flySpeed = v flyLabel.Text = "Fly Speed: "..v end)
handleSlider(walkThumb, walkTrack, 16, 150, function(v) walkSpeedVal = v walkLabel.Text = "Walk Speed: "..v if humanoid then humanoid.WalkSpeed = v end end)

-- Fly Logic
flyBtn.MouseButton1Click:Connect(function()
	flying = not flying
	flyBtn.Text = flying and "Fly: ON" or "Fly: OFF"
	if flying then
		humanoid.PlatformStand = true
		bodyVelocity = Instance.new("BodyVelocity", rootPart)
		bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
		bodyGyro = Instance.new("BodyGyro", rootPart)
		bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
		task.spawn(function()
			while flying do
				local cam = workspace.CurrentCamera
				local dir = Vector3.new(0,0,0)
				if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir += cam.CFrame.LookVector end
				if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir -= cam.CFrame.LookVector end
				if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir -= cam.CFrame.RightVector end
				if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir += cam.CFrame.RightVector end
				bodyVelocity.Velocity = dir.Magnitude > 0 and dir.Unit * flySpeed or Vector3.new(0,0,0)
				bodyGyro.CFrame = cam.CFrame
				task.wait()
			end
		end)
	else
		if bodyVelocity then bodyVelocity:Destroy() end
		if bodyGyro then bodyGyro:Destroy() end
		humanoid.PlatformStand = false
	end
end)

