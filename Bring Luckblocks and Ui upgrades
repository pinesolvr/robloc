-- 1. Disable Sharks (Hides them and moves them far away)
sharkBtn.MouseButton1Click:Connect(function()
    sharksDisabled = not sharksDisabled
    sharkBtn.Text = "DISABLE SHARKS: " .. (sharksDisabled and "ON" or "OFF")
    sharkBtn.BackgroundColor3 = sharksDisabled and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(0, 120, 200)
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name:lower():find("shark") and obj:IsA("Model") then
            if sharksDisabled then
                obj:MoveTo(Vector3.new(0, -1000, 0)) -- Move under map
            else
                obj:MoveTo(rootPart.Position + Vector3.new(0, 20, 50)) -- Bring back near
            end
        end
    end
end)

-- 2. Bring LuckyBlocks and Brainrots
bringBtn.MouseButton1Click:Connect(function()
    local count = 0
    for _, item in pairs(workspace:GetDescendants()) do
        if (item.Name:lower():find("luckyblock") or item.Name:lower():find("brainrot")) and item:IsA("BasePart") then
            item.CFrame = rootPart.CFrame + Vector3.new(0, 3, 0)
            count += 1
        elseif item:IsA("Model") and (item.Name:lower():find("luckyblock") or item.Name:lower():find("brainrot")) then
            item:MoveTo(rootPart.Position + Vector3.new(0, 3, 0))
            count += 1
        end
    end
    print("Brought " .. count .. " items!")
end)

-- 3. Boat Time Limit (Client-side bypass attempt)
